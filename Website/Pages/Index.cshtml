@page
@model IndexModel

<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Julian's Website</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #0a0a0a;
            color: #ffffff;
        }

        /* Navigation */
        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 60px;
            background-color: #111111;
            border-bottom: 2px solid #00d4ff;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .logo {
            font-size: 1.8rem;
            font-weight: bold;
            color: #00d4ff;
            letter-spacing: 2px;
        }

        .nav-links a {
            color: #ffffff;
            text-decoration: none;
            margin-left: 30px;
            font-size: 1rem;
            transition: color 0.3s;
        }

        .nav-links a:hover {
            color: #00d4ff;
        }

        /* Hero Section */
        .hero {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 90vh;
            text-align: center;
            padding: 40px;
            background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 100%);
        }

        .hero h1 {
            font-size: 3.5rem;
            margin-bottom: 20px;
            color: #ffffff;
        }

        .hero h1 span {
            color: #00d4ff;
        }

        .hero p {
            font-size: 1.3rem;
            color: #aaaaaa;
            max-width: 600px;
            margin-bottom: 40px;
            line-height: 1.8;
        }

        .btn {
            padding: 15px 40px;
            background-color: #00d4ff;
            color: #000000;
            border: none;
            border-radius: 30px;
            font-size: 1rem;
            font-weight: bold;
            cursor: pointer;
            text-decoration: none;
            transition: transform 0.3s, background-color 0.3s;
        }

        .btn:hover {
            background-color: #00b8d9;
            transform: scale(1.05);
        }

        /* About Section */
        .about {
            padding: 80px 60px;
            background-color: #111111;
            text-align: center;
        }

        .about h2 {
            font-size: 2.5rem;
            color: #00d4ff;
            margin-bottom: 20px;
        }

        .about p {
            font-size: 1.1rem;
            color: #cccccc;
            max-width: 700px;
            margin: 0 auto;
            line-height: 1.9;
        }

        /* Skills Section */
        .skills {
            padding: 80px 60px;
            background-color: #0a0a0a;
            text-align: center;
        }

        .skills h2 {
            font-size: 2.5rem;
            color: #00d4ff;
            margin-bottom: 40px;
        }

        .skills-grid {
            display: flex;
            justify-content: center;
            gap: 30px;
            flex-wrap: wrap;
        }

        .skill-card {
            background-color: #1a1a2e;
            border: 1px solid #00d4ff;
            border-radius: 15px;
            padding: 30px 40px;
            width: 180px;
            transition: transform 0.3s;
        }

        .skill-card:hover {
            transform: translateY(-10px);
        }

        .skill-card .icon {
            font-size: 2.5rem;
            margin-bottom: 10px;
        }

        .skill-card p {
            color: #ffffff;
            font-size: 1rem;
        }

        /* Contact Section */
        .contact {
            padding: 80px 60px;
            background-color: #111111;
            text-align: center;
        }

        .contact h2 {
            font-size: 2.5rem;
            color: #00d4ff;
            margin-bottom: 20px;
        }

        .contact p {
            color: #cccccc;
            font-size: 1.1rem;
            margin-bottom: 30px;
        }

        .contact a {
            color: #00d4ff;
            text-decoration: none;
            font-size: 1.2rem;
        }

        /* Footer */
        footer {
            text-align: center;
            padding: 20px;
            background-color: #0a0a0a;
            color: #555555;
            font-size: 0.9rem;
            border-top: 1px solid #222222;
        }
    </style>
</head>
<body>

    <!-- Navigation -->
    <nav>
        <div class="logo">Julian.</div>
        <div class="nav-links">
            <a href="#about">Über mich</a>
            <a href="#skills">Skills</a>
            <a href="#contact">Kontakt</a>
        </div>
    </nav>

    <!-- Hero -->
    <section class="hero">
        <h1>Hi, ich bin <span>Julian</span> 👋</h1>
        <p>Willkommen auf meiner persönlichen Website. Hier zeige ich wer ich bin, was ich kann und was mich begeistert.</p>
        <a href="#about" class="btn">Mehr erfahren</a>
    </section>

    <!-- About -->
    <section class="about" id="about">
        <h2>Über mich</h2>
        <p>
            Ich bin Julian, [dein Alter] Jahre alt und interessiere mich für [deine Interessen].
            Hier kannst du mehr über mich schreiben – was dich antreibt, was du machst und was deine Ziele sind.
        </p>
    </section>

    <!-- Skills -->
    <section class="skills" id="skills">
        <h2>Meine Skills</h2>
        <div class="skills-grid">
            <div class="skill-card">
                <div class="icon">💻</div>
                <p>HTML & CSS</p>
            </div>
            <div class="skill-card">
                <div class="icon">⚙️</div>
                <p>C#</p>
            </div>
            <div class="skill-card">
                <div class="icon">🚀</div>
                <p>GitHub</p>
            </div>
            <div class="skill-card">
                <div class="icon">🎯</div>
                <p>Dein Skill</p>
            </div>
        </div>
    </section>

    <!-- Contact -->
    <section class="contact" id="contact">
        <h2>Kontakt</h2>
        <p>Du möchtest mich erreichen? Schreib mir gerne!</p>
        <a href="mailto:deine@email.de">📧 deine@email.de</a>
    </section>

    <!-- Footer -->
    <footer>
        <p>© 2025 Julian. Alle Rechte vorbehalten.</p>
    </footer>

</body>
</html>